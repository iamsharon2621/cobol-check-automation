{
  "$schema": "https://githubusercontent.com",
  "profiles": {
    "base": {
      "type": "base",
      "properties": {
        "host": "${{ variables.ZOWE_ZOSMF_HOST }}",
        "port": 10443,
        "user": "${{ secrets.ZOWE_USERNAME }}",
        "password": "${{ secrets.ZOWE_PASSWORD }}",
        "rejectUnauthorized": false
      },
      "secure": [
        "user",
        "password"
      ]
    },
    "ssh": {
      "type": "ssh",
      "properties": {
        "port": 22,
        "host": "${{ variables.ZOWE_ZOSMF_HOST }}",
        "port": 10443,
        "user": "${{ secrets.ZOWE_USERNAME }}",
        "password": "${{ secrets.ZOWE_PASSWORD }}"
      },
      "secure": [
        "user",
        "password"
      ]
    },
    "zosmf": {
      "type": "zosmf",
      "properties": {}
    }
  },
  "defaults": {
    "zosmf": "zosmf",
    "ssh": "ssh",
    "base": "base"
  }
}
