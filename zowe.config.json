{
  "$schema": "https://githubusercontent.com",
  "profiles": {
    "base": {
      "type": "base",
      "properties": {
        "host": "${ZOWE_ZOSMF_HOST}",
        "port": 10443,
        "user": "${ZOWE_USERNAME}",
        "password": "${ZOWE_PASSWORD}",
        "rejectUnauthorized": false
      },
      "secure": [
        "user",
        "password"
      ]
    },
    "ssh": {
      "type": "ssh",
      "properties": {
        "port": 22,
        "host": "${ZOWE_ZOSMF_HOST}",
        "port": 10443,
        "user": "${ZOWE_USERNAME}",
        "password": "${ZOWE_PASSWORD}"
      },
      "secure": [
        "user",
        "password"
      ]
    },
    "zosmf": {
      "type": "zosmf",
      "properties": {}
    }
  },
  "defaults": {
    "zosmf": "zosmf",
    "ssh": "ssh",
    "base": "base"
  }
}
